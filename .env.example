POSTGRES_DB=archetypeos
POSTGRES_USER=archetypeos
POSTGRES_PASSWORD=archetypeos
# Host-side port mappings. When co-hosting with other stacks (e.g. a local
# Plane instance whose Postgres owns 5432), change only these host ports —
# container-internal wiring (DATABASE_URL/REDIS_URL below) is unaffected.
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8000
WEB_PORT=5173
DATABASE_URL=postgresql+psycopg://archetypeos:archetypeos@postgres:5432/archetypeos
REDIS_URL=redis://redis:6379/0
ARTIFACT_ROOT=/data/artifacts
REPOSITORY_ROOT=/repositories
HOST_REPOSITORY_ROOT=./repositories
CORS_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

# --- LLM provider (AOS-LLM-LOCAL-001) ---------------------------------------
# Default is the hermetic "deterministic" provider (no network, CI-safe). To run
# the reasoned tiers (distillation / council / research) off Claude and save
# subscription tokens, set llm_provider=openai_compatible and point it at either:
#   • a LOCAL model on the node (teevee's RTX 3070 via Ollama):
#       LLM_PROVIDER=openai_compatible
#       LLM_BASE_URL=http://localhost:11434/v1
#       LLM_MODEL=qwen2.5-coder:7b        # `ollama pull qwen2.5-coder:7b` (fits 8GB)
#       LLM_API_KEY=                       # local Ollama needs no key
#   • a FREE hosted API (free-llm-api-resources catalog — e.g. Groq):
#       LLM_PROVIDER=openai_compatible
#       LLM_BASE_URL=https://api.groq.com/openai/v1
#       LLM_MODEL=llama-3.3-70b-versatile
#       LLM_API_KEY=<key>                  # keep in the env / a chmod-600 .env, never commit
LLM_PROVIDER=deterministic
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5-coder:7b
LLM_API_KEY=

# --- Research Engine web tier (RFC-0012 / AOS-RESEARCH-002) ------------------
# Default OFF → build_web_source() returns None → the engine uses the hermetic
# LocalCorpusSource (no network). Set RESEARCH_WEB_ENABLED=true and configure the
# discovery/fetch backends to activate the web tier. A backend joins the pool only
# when its host/key is set (like the free-LLM pool). Start the self-hosted
# services with `docker compose --profile research up`. Names only below — never
# commit the EXA_API_KEY secret value.
RESEARCH_WEB_ENABLED=false
EXA_API_KEY=
CRAWL4AI_URL=
SEARXNG_URL=
FIRECRAWL_URL=
RESEARCH_HTTP_TIMEOUT=
RESEARCH_MAX_FETCH=
RESEARCH_RETRY_BUDGET=
