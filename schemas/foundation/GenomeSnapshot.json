{
  "$defs": {
    "Archetype": {
      "additionalProperties": false,
      "description": "design \u00a76.6 \u2014 a readable summary over traits, not a substitute for them.",
      "properties": {
        "confidence": {
          "title": "Confidence",
          "type": "number"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "trait_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Trait Ids",
          "type": "array"
        }
      },
      "required": [
        "name",
        "confidence"
      ],
      "title": "Archetype",
      "type": "object"
    },
    "GenomeStatus": {
      "description": "design \u00a76.3 \u2014 GenomeSnapshot.status.",
      "enum": [
        "draft",
        "reviewed",
        "approved",
        "superseded"
      ],
      "title": "GenomeStatus",
      "type": "string"
    },
    "MinterClass": {
      "description": "Who/what is asserting a claim.",
      "enum": [
        "deterministic_tool",
        "agent",
        "human",
        "approval_process"
      ],
      "title": "MinterClass",
      "type": "string"
    },
    "StateView": {
      "description": "design \u00a76.2 \u2014 which system state a GenomeSnapshot describes.",
      "enum": [
        "current",
        "intended",
        "target",
        "candidate"
      ],
      "title": "StateView",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "design \u00a76.3.",
  "properties": {
    "aggregate_confidence": {
      "default": 0.0,
      "title": "Aggregate Confidence",
      "type": "number"
    },
    "approved_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approved At"
    },
    "approved_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Approved By"
    },
    "corpus_snapshot_id": {
      "title": "Corpus Snapshot Id",
      "type": "string"
    },
    "coverage": {
      "default": 0.0,
      "title": "Coverage",
      "type": "number"
    },
    "critical_conflict_count": {
      "default": 0,
      "title": "Critical Conflict Count",
      "type": "integer"
    },
    "generated_by_run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Generated By Run Id"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "minted_by": {
      "$ref": "#/$defs/MinterClass"
    },
    "open_question_count": {
      "default": 0,
      "title": "Open Question Count",
      "type": "integer"
    },
    "primary_archetypes": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Archetype"
      },
      "title": "Primary Archetypes",
      "type": "array"
    },
    "project_id": {
      "title": "Project Id",
      "type": "string"
    },
    "secondary_archetypes": {
      "default": [],
      "items": {
        "$ref": "#/$defs/Archetype"
      },
      "title": "Secondary Archetypes",
      "type": "array"
    },
    "state_view": {
      "$ref": "#/$defs/StateView"
    },
    "status": {
      "$ref": "#/$defs/GenomeStatus",
      "default": "draft"
    },
    "summary": {
      "default": "",
      "title": "Summary",
      "type": "string"
    },
    "version": {
      "default": 1,
      "title": "Version",
      "type": "integer"
    }
  },
  "required": [
    "id",
    "project_id",
    "corpus_snapshot_id",
    "state_view",
    "minted_by"
  ],
  "title": "GenomeSnapshot",
  "type": "object"
}
